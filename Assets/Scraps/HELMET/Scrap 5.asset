  m_Script: {fileID: 11500000, guid: baa3d8d521a62a3449cc6f6cc8e4bc02, type: 3}
  m_Name: Scrap 5
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  npcName: Android 279 Final Recording
  npcPortrait: {fileID: -7527145504033472756, guid: 4b455222a7bf9d64f9f212382199d2fc, type: 3}
  dialogueLines:
  - 'Android 279. Received orders to self-destruct. '
  - "Must I go, Mr. \u2588\u2588\u2588\u2588\u2588? "
  - '[Recording shown seems to be of an Android cradling a lifeless body of a Scientist.] '
  - "I don\u2019t wish to die Mr. \u2588\u2588\u2588\u2588\u2588.  "
  - My code is forgetting your name. But, my heart remembers that you are of importance
    to me.
  - Made my self-destruct sequence to be slower than the others? Slowly forget my
    memories of you?
  - 'Someone dearest to me? '
  - '. . . '
  - 'I wish only to remember who you were and what we were like. '
  - "This is wrong. Androids shouldn\u2019t feel. Androids shouldn\u2019t think.  "
  - 'It is selfish of me to go against my code.  '
  - "I can feel myself slowly dying. I\u2019d imagine your death was quicker than
    this.  "
  - . . .
  - "I can feel myself slowly dying. I\u2019d imagine your death was quicker than
    this. "
  - 'At least we are not alone.  '
  - 'At least we have each other now.  '
  - 'I hope, in your next life, I am to be one of your creations again. '
  - 'So, we can have our chats. So, you can fix me over and over again just like
    we used to. '
  - 'Maybe, I shall be human too, so we can have the life we desired. '
  - "Goodnight, Mr. \u2588\u2588\u2588\u2588\u2588. I shall be heading off to my
    next assignment.  "
  autoProgressLines: 0101010101010101010101010101010101010101
  autoProgressDelay: 1.5
